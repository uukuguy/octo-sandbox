# Root-level temp tests only (crates/*/tests/ are real integration tests, must be committed).
# Exception: tests/contract/ is the EAASP v2.0 cross-runtime contract suite
# (Phase 2.5 S0, ADR-V2-017). Listing excluded subpaths individually so that
# tests/contract/ stays tracked (git cannot re-include under a wildcard-excluded parent).
/tests/*
!/tests/contract/
!/tests/e2e/
tests/e2e/__pycache__/
tests/e2e/**/__pycache__/
tests/contract/**/__pycache__/
tests/contract/.pytest_cache/

# dev-eaasp runtime logs
.logs/

.grid/
.e2e/
.omc/

# claude code session artifacts
.claude/scheduled_tasks.lock

# runtime artifacts
grid-runtime.db
*.log
docs/design/AgentOS/
