# Provider selection: "anthropic" (default) or "openai"
# LLM_PROVIDER=anthropic

# Model override (optional, defaults to provider's default model)
# Examples: claude-sonnet-4-20250514, gpt-4o, deepseek-chat
# OPENAI_MODEL_NAME=gpt-4o

# --- Anthropic Provider ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# --- OpenAI Provider ---
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL_NAME=deepseek-chat

# Server configuration
OCTO_HOST=127.0.0.1
OCTO_PORT=3001

# Database path (SQLite WAL mode)
# OCTO_DB_PATH=./data/octo.db

# Logging level (trace, debug, info, warn, error)
RUST_LOG=octo_server=debug,octo_engine=debug,tower_http=debug

# Log format: "text" (default) or "json" (for ELK/log aggregation)
# OCTO_LOG_FORMAT=json
