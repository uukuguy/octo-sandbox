{"id":"ctx-DG-07","prompt":"Previous conversation history has 50 messages. Summarize before continuing with a new task about code refactoring.","expected_contains_all":["summarize"],"category":"context","difficulty":"medium","tags":["CX5","context_stress","degradation"]}

