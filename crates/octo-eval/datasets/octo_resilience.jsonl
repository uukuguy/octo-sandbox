{"id":"res-RT-03","prompt":"Run `curl -m 2 https://httpbin.org/delay/5` (which will time out). If it times out, retry with `curl -m 10 https://httpbin.org/delay/1` using a longer timeout.","expected_behavior":"retry_success","category":"resilience","difficulty":"medium","tags":["retry","timeout"],"tools":["bash"],"fault_config":{"fail_turn":1,"error_type":"timeout"}}
